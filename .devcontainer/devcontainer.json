{
  "name": "ProjectManager",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "version": "latest",
      "noVncVersion": "1.5.0",
      "password": "vscode",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },

  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": { "label": "Desktop (noVNC)", "onAutoForward": "openBrowser" }
  },

  "postCreateCommand": "pip install -r requirements.txt && pip install pytest && sudo apt-get update -qq && sudo apt-get install -y -qq python3-tk chromium --no-install-recommends",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
