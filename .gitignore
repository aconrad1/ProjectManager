# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ──────────────────────────────────────────────────────────────────────────────
# User / Profile Data  (NEVER commit personal data)
# ──────────────────────────────────────────────────────────────────────────────
# Company folders contain workbooks, domain.json, notes, links, attachments,
# exports, and reports — all personal to each user.
profiles/*/

# BUT allow the dev/test profile (fake data, safe to commit)
!profiles/_TestCompany/

# Template workbook (generated, not source)
profiles/_template.xlsx

# ──────────────────────────────────────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key

# ──────────────────────────────────────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────────
# OS junk
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
